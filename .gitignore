# Python bytecode
__pycache__/
*.pyc

# Build artifacts — the installable bundle is generated from the source tree.
# A .plugin is a zip with the manifest at the archive root (see BUILD.md);
# *.zip covers older builds and any intermediate archive.
*.plugin
*.zip

# Local scratch / working dirs — never committed.
# Convention: any directory whose name starts with "_" is local-only scratch, at
# any depth. The skill uses _work/ for its per-run download -> compute -> upload
# cycle; _dryrun/ is handy for local test data.
_*/

# Python environments & tool caches (if used locally)
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS cruft
.DS_Store

# Claude Code local working dir (agent worktrees) — never commit
.claude/
